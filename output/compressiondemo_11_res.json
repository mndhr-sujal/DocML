    "parsing_res_list": [
        {
            "block_label": "text",
            "block_content": "PaddleOCR (PP-StructureV3): Achieves state-of-the-art performance on OmniDocBench with <10oM parameters, offering superior open-source local deployment. Native Markdown output lacks layout preservation, requiring custom reconstruction [6,7].\n\n",
            "block_bbox": [
                248,
                167,
                1029,
                315
            ],
            "block_id": 0,
            "block_order": 1
        },
        {
            "block_label": "paragraph_title",
            "block_content": "#### 2.4. Security Considerations ",
            "block_bbox": [
                211,
                374,
                549,
                398
            ],
            "block_id": 1,
            "block_order": 2
        },
        {
            "block_label": "text",
            "block_content": "OCR systems process sensitive personal information, making architectural decisions critical. Cloud solutions require external transmission, introducing data leak risks and privacy concerns. Local execution significantly reduces the risk of data leakage by ensuring data remains on-device, providing the capability to process and store the data on a local database and to feed it into other processes, all of which can be done on the local machine. For hybrid architectures using cloud LLMs, techniques including anonymization, redaction, and query abstraction reduce privacy risks [12]. Local execution of any part of the process reduces privacy concerns and the risk of data theft.\n\n",
            "block_bbox": [
                210,
                461,
                1044,
                814
            ],
            "block_id": 2,
            "block_order": 3
        },
        {
            "block_label": "paragraph_title",
            "block_content": "#### 2.5. Solutions Proposed by our System ",
            "block_bbox": [
                212,
                874,
                670,
                901
            ],
            "block_id": 3,
            "block_order": 4
        },
        {
            "block_label": "text",
            "block_content": "The proposed system overcomes the aforementioned limitations through an AI-enhanced, user-friendly OCR platform designed for a wide range of document types and user needs. Key features include:",
            "block_bbox": [
                211,
                962,
                1044,
                1074
            ],
            "block_id": 4,
            "block_order": 5
        },
        {
            "block_label": "text",
            "block_content": "• It can recognize handwritten and printed text with high accuracy in a variety of languages and complicated layouts ",
            "block_bbox": [
                248,
                1115,
                1019,
                1182
            ],
            "block_id": 5,
            "block_order": 6
        },
        {
            "block_label": "text",
            "block_content": "It accurately reconstructs the original layout of documents into editable format.\n\n",
            "block_bbox": [
                248,
                1222,
                972,
                1285
            ],
            "block_id": 6,
            "block_order": 7
        },
        {
            "block_label": "text",
            "block_content": "Scanned documents can be converted into DOCX, PDF, and HTML, among other formats.\n\n",
            "block_bbox": [
                248,
                1329,
                1016,
                1392
            ],
            "block_id": 7,
            "block_order": 8
        },
        {
            "block_label": "text",
            "block_content": "An integrated AI assistant assists users with understanding terms, answering questions, and interpreting content.\n\n",
            "block_bbox": [
                247,
                1436,
                1020,
                1501
            ],
            "block_id": 8,
            "block_order": 9
        },
        {
            "block_label": "number",
